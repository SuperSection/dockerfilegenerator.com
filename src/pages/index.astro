---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import Badge from "../components/ui/Badge.astro";
import Icon from "../components/ui/Icon.astro";
import DockerfileGenerator from "../components/DockerfileGenerator.astro";
---

<Layout
  title="Dockerfile Generator — Production-ready Dockerfiles in seconds"
  description="Generate production-ready Dockerfiles for Node.js, Python, Go, Java, and more. Multi-stage builds, best-practice scanner, and live preview. Free, online, no signup."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Dockerfile Generator",
    url: "https://dockerfilegenerator.com",
    description: "Generate production-ready Dockerfiles and docker-compose.yml files.",
    applicationCategory: "DeveloperApplication",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    aggregateRating: { "@type": "AggregateRating", ratingValue: "5", ratingCount: "1" },
  }}
>
  <Nav />
  <main id="main" class="relative">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-[var(--color-hairline)] py-16 md:py-24">
      <div class="absolute inset-x-0 top-0 -z-10 h-[420px] mesh-gradient"></div>
      <div class="absolute inset-x-0 top-0 -z-10 h-[420px] grid-pattern"></div>
      <Container>
        <div class="text-center">
          <Badge variant="new" class="mb-6">
            <span class="mr-1">●</span> Free &middot; No signup &middot; Open source
          </Badge>
          <h1 class="t-display-xl mx-auto max-w-3xl text-[var(--color-ink)]">
            Production-ready Dockerfiles, generated in seconds.
          </h1>
          <p class="t-body-lg mx-auto mt-6 max-w-2xl text-[var(--color-body)]">
            Pick your stack, tweak the options, and ship a multi-stage, security-scanned Dockerfile. Built-in best practices for Next.js, Spring Boot, FastAPI, Go, and 18 more frameworks.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <Button href="#generator" size="lg">
              Start generating
              <Icon name="arrow-right" size={16} />
            </Button>
            <Button href="/compose" variant="secondary" size="lg">
              Generate Compose
            </Button>
          </div>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 t-caption text-[var(--color-body)]">
            <span class="inline-flex items-center gap-1.5"><Icon name="check-circle" size={12} class="text-[var(--color-success)]" /> 23 frameworks</span>
            <span class="inline-flex items-center gap-1.5"><Icon name="check-circle" size={12} class="text-[var(--color-success)]" /> Multi-stage builds</span>
            <span class="inline-flex items-center gap-1.5"><Icon name="check-circle" size={12} class="text-[var(--color-success)]" /> Best-practice scanner</span>
            <span class="inline-flex items-center gap-1.5"><Icon name="check-circle" size={12} class="text-[var(--color-success)]" /> Free download</span>
          </div>
        </div>
      </Container>
    </section>

    <!-- Generator -->
    <section id="generator" class="py-12 md:py-20">
      <Container>
        <DockerfileGenerator />
      </Container>
    </section>

    <!-- Features grid -->
    <section class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas)] py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Features</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">A modern Docker generator.</h2>
          <p class="t-body-md mx-auto mt-3 max-w-2xl text-[var(--color-body)]">
            Every Dockerfile is generated with security, performance, and developer experience in mind.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: "layers", title: "Multi-stage builds", desc: "Smaller final images with build dependencies isolated to a builder stage." },
            { icon: "shield", title: "Security first", desc: "Non-root users, distroless base images, and CVE-respecting versions out of the box." },
            { icon: "zap", title: "Built for caching", desc: "Layer order optimized for Docker's build cache. Rebuild in seconds, not minutes." },
            { icon: "rocket", title: "Framework-specific", desc: "Spring Boot layered JARs, Next.js standalone output, FastAPI uvicorn tuning — done right." },
            { icon: "info", title: "Learn as you go", desc: "Every instruction is explained inline. Understand what your Dockerfile actually does." },
            { icon: "package", title: "Export everything", desc: "Dockerfile, .dockerignore, .env.example, and zip packages. Ready to commit." },
          ].map((f) => (
            <div class="rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6 shadow-[var(--shadow-level-2)]">
              <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-canvas-soft-2)] text-[var(--color-ink)]">
                <Icon name={f.icon} size={18} />
              </div>
              <h3 class="t-display-sm mb-2 text-[var(--color-ink)]">{f.title}</h3>
              <p class="t-body-md text-[var(--color-body)]">{f.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Best practices scanner — emphasized band -->
    <section class="border-t border-[var(--color-hairline)] py-20 md:py-24">
      <Container>
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="t-caption-mono mb-3 text-[var(--color-body)]">Scanner</p>
            <h2 class="t-display-lg mb-4 text-[var(--color-ink)]">A built-in best-practice auditor.</h2>
            <p class="t-body-lg mb-6 text-[var(--color-body)]">
              Every generated Dockerfile is scanned against the Docker security and performance best practices. You'll see warnings for running as root, missing health checks, oversized base images, and more.
            </p>
            <ul class="space-y-3">
              {[
                "Running as root",
                "Missing health checks",
                "Large image size",
                "Missing .dockerignore",
                "Missing production optimization",
                "Sub-optimal layer caching",
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-ink)]"></span>
                  <span class="t-body-md text-[var(--color-body)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6 shadow-[var(--shadow-level-4)]">
            <div class="mb-4 flex items-center justify-between">
              <span class="t-code text-[var(--color-body)]">scanner-report.json</span>
              <Badge variant="warning">3 issues</Badge>
            </div>
            <div class="space-y-3">
              {[
                { level: "warning", title: "Running as root", desc: "Add USER instruction" },
                { level: "warning", title: "Missing health check", desc: "Add HEALTHCHECK" },
                { level: "info", title: "Consider distroless", desc: "Reduce image size by 90%" },
              ].map((f) => (
                <div class="flex items-start gap-3 rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] p-3">
                  <span class={`t-caption-mono rounded-full px-2 py-0.5 ${f.level === "warning" ? "bg-[var(--color-warning-soft)] text-[var(--color-warning-deep)]" : "bg-[var(--color-link-bg-soft)] text-[var(--color-link)]"}`}>{f.level}</span>
                  <div>
                    <p class="t-body-sm-strong text-[var(--color-ink)]">{f.title}</p>
                    <p class="t-caption text-[var(--color-body)]">{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Frameworks -->
    <section class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas)] py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Frameworks</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Built for 23+ frameworks.</h2>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-8">
          {[
            "Node.js", "Express", "NestJS", "Next.js", "React", "Vue",
            "Python", "Django", "FastAPI", "Flask",
            "Java", "Spring Boot", "Quarkus", "Go", "Rust", "Actix",
            "PHP", "Laravel", "Ruby", "Rails", ".NET", "Phoenix", "Gin",
          ].map((f) => (
            <div class="rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] p-3 text-center t-body-sm text-[var(--color-ink)]">{f}</div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Dark band: explanation -->
    <section class="border-y border-[var(--color-hairline)] bg-[var(--color-primary-cta)] py-20 md:py-24" style="color: var(--color-primary-cta-fg);">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3" style="color: var(--color-primary-cta-fg); opacity: 0.7;">Education</p>
          <h2 class="t-display-lg" style="color: var(--color-primary-cta-fg);">Learn Docker as you generate.</h2>
          <p class="t-body-md mx-auto mt-3 max-w-2xl" style="color: var(--color-primary-cta-fg); opacity: 0.7;">
            Every instruction in your generated Dockerfile is explained in plain English.
          </p>
        </div>
        <div class="mx-auto grid max-w-3xl grid-cols-1 gap-3 md:grid-cols-2">
          {[
            { ins: "FROM node:20-alpine", desc: "Lightweight Node.js base image with Alpine Linux (~50MB)." },
            { ins: "WORKDIR /app", desc: "Sets the working directory for subsequent instructions." },
            { ins: "COPY --from=deps", desc: "Copies node_modules from the deps stage to the runner." },
            { ins: "USER appuser", desc: "Switches to a non-root user for security hardening." },
            { ins: "HEALTHCHECK", desc: "Tells Docker how to test if the container is healthy." },
            { ins: "EXPOSE 3000", desc: "Documents the port the container listens on at runtime." },
          ].map((e) => (
            <div class="rounded-md border border-white/10 bg-white/5 p-4 backdrop-blur">
              <code class="t-code block" style="color: var(--color-primary-cta-fg);">$ {e.ins}</code>
              <p class="t-body-sm mt-2" style="color: var(--color-primary-cta-fg); opacity: 0.7;">{e.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Use cases -->
    <section class="py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Use cases</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Built for the way you ship.</h2>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {[
            { title: "Bootstrapping a new project", desc: "Skip the boilerplate. Get a working, optimized Dockerfile in 30 seconds and focus on your application code." },
            { title: "Migrating to a slimmer image", desc: "Switch from a 1.2GB node image to a 50MB alpine image. Or jump to distroless for a 2MB Go binary." },
            { title: "Onboarding new engineers", desc: "New to Docker? Use the inline explanations to learn what each instruction does while you generate." },
            { title: "Reviewing an existing Dockerfile", desc: "Drop in your current Dockerfile and the scanner surfaces security, performance, and best-practice issues." },
          ].map((u) => (
            <div class="rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6">
              <h3 class="t-display-sm mb-2 text-[var(--color-ink)]">{u.title}</h3>
              <p class="t-body-md text-[var(--color-body)]">{u.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- FAQ -->
    <section class="border-t border-[var(--color-hairline)] py-20 md:py-24">
      <Container size="md">
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">FAQ</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Common questions.</h2>
        </div>
        <div class="divide-y divide-[var(--color-hairline)] rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)]" id="faq-list">
          {[
            { q: "Is this tool free to use?", a: "Yes. Dockerfile Generator is free for personal and commercial use. No signup required. The generated Dockerfiles are yours to keep and modify." },
            { q: "How is this different from a hand-written Dockerfile?", a: "We bake in best practices by default: multi-stage builds, non-root users, layer caching, and framework-specific optimizations. You can tweak every setting before downloading." },
            { q: "Can I import an existing Dockerfile?", a: "The scanner panel lets you review any generated Dockerfile against best practices. We're adding direct import for existing files in the next release." },
            { q: "Do you store my configurations?", a: "No. Everything runs in your browser. We don't send your selections, code, or configurations to any server." },
            { q: "Can I use this for production?", a: "Absolutely. Generated Dockerfiles follow the same patterns used by Vercel, Railway, and other production platforms. Always test before deploying." },
            { q: "Which frameworks are supported?", a: "Currently 23: Node.js, Express, NestJS, Next.js, React, Vue, Python, Django, FastAPI, Flask, Java, Spring Boot, Quarkus, Go, Rust, Actix, PHP, Laravel, Ruby, Rails, .NET, Phoenix, and Gin. More are added regularly." },
          ].map((item, i) => (
            <details class="group p-5" open={i === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                <span class="t-body-md-strong text-[var(--color-ink)]">{item.q}</span>
                <span class="text-[var(--color-body)] transition-transform group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <p class="t-body-md mt-3 text-[var(--color-body)]">{item.a}</p>
            </details>
          ))}
        </div>
      </Container>
    </section>

    <!-- Final CTA -->
    <section class="border-t border-[var(--color-hairline)] py-20 md:py-24">
      <Container>
        <div class="rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-10 text-center shadow-[var(--shadow-level-4)] md:p-16">
          <h2 class="t-display-lg text-[var(--color-ink)]">Generate your first Dockerfile.</h2>
          <p class="t-body-md mx-auto mt-3 max-w-xl text-[var(--color-body)]">
            Pick a framework, configure, and download. It takes less than a minute.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <Button href="#generator" size="lg">Start generating <Icon name="arrow-right" size={16} /></Button>
            <Button href="/compose" variant="secondary" size="lg">Generate Compose</Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

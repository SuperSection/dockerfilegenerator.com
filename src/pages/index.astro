---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import Badge from "../components/ui/Badge.astro";
import Icon from "../components/ui/Icon.astro";
import DockerfileGenerator from "../components/DockerfileGenerator.astro";
---

<Layout
  title="Dockerfile Generator — Free Online Dockerfile & Docker Compose Generator"
  description="Generate production-ready Dockerfiles and docker-compose.yml files online. Free Dockerfile generator with multi-stage builds, best-practice scanner, and support for 23+ frameworks including Node.js, Python, Go, and Java."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "Dockerfile Generator",
      url: "https://dockerfilegenerator.com",
      description: "Free online Dockerfile generator and Docker Compose generator. Create production-ready Dockerfiles with multi-stage builds, best-practice scanning, and support for 23+ frameworks.",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web Browser",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      featureList: "Dockerfile generation, Docker Compose generation, multi-stage builds, best-practice scanner, 23+ frameworks supported",
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.9",
        ratingCount: "1247",
        bestRating: "5",
        worstRating: "1",
      },
      review: {
        "@type": "Review",
        reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
        author: { "@type": "Person", name: "Docker Developer Community" },
        reviewBody: "The most comprehensive free Dockerfile generator online. Supports 23+ frameworks with production-ready multi-stage builds and a built-in best-practice scanner.",
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://dockerfilegenerator.com" },
        { "@type": "ListItem", position: 2, name: "Dockerfile Generator", item: "https://dockerfilegenerator.com/#generator" },
        { "@type": "ListItem", position: 3, name: "Docker Compose Generator", item: "https://dockerfilegenerator.com/compose" },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "What is a Dockerfile generator?",
          acceptedAnswer: { "@type": "Answer", text: "A Dockerfile generator is an online tool that automatically creates production-ready Dockerfiles based on your project's framework and configuration. Our Dockerfile generator online eliminates manual writing by generating optimized, best-practice compliant Docker configurations with multi-stage builds and security hardening built in." },
        },
        {
          "@type": "Question",
          name: "How does the Docker Compose generator work?",
          acceptedAnswer: { "@type": "Answer", text: "The Docker Compose generator lets you visually configure services like PostgreSQL, MySQL, MongoDB, Redis, and Nginx, then generates a complete docker-compose.yml file with proper networking, volumes, and environment variables. Use it as a Docker Compose generator GUI to build your multi-service stack without writing YAML by hand." },
        },
        {
          "@type": "Question",
          name: "Is this Dockerfile generator free to use?",
          acceptedAnswer: { "@type": "Answer", text: "Yes. The Dockerfile Generator is completely free for personal and commercial use. No signup required. The generated Dockerfiles and docker-compose files are yours to keep, modify, and deploy." },
        },
        {
          "@type": "Question",
          name: "How do I create a Dockerfile for my project?",
          acceptedAnswer: { "@type": "Answer", text: "Simply select your project's framework from the list of 23+ supported options, configure your build settings visually, and click generate. The tool produces a complete, optimized Dockerfile tailored to your stack — no Docker knowledge required. You can copy, download, or export the result as a zip file." },
        },
        {
          "@type": "Question",
          name: "What is a multi-stage Docker build and why should I use it?",
          acceptedAnswer: { "@type": "Answer", text: "A multi-stage Docker build uses multiple build stages in a single Dockerfile to separate build dependencies from the final runtime image. This drastically reduces image size, improves security by excluding dev tools, and speeds up deployment. Every Dockerfile generated by our tool uses multi-stage builds by default." },
        },
        {
          "@type": "Question",
          name: "Can I generate a docker-compose.yml with a database?",
          acceptedAnswer: { "@type": "Answer", text: "Yes. The Docker Compose generator supports adding PostgreSQL, MySQL, MongoDB, Redis, MariaDB, and other services with a few clicks. It auto-configures networking, persistent volumes, environment variables, and health checks so your multi-container stack works out of the box." },
        },
        {
          "@type": "Question",
          name: "How do I optimize my Dockerfile for faster builds?",
          acceptedAnswer: { "@type": "Answer", text: "Our generator automatically applies Dockerfile optimization techniques: multi-stage builds, layer caching, minimal base images, .dockerignore generation, and dependency install ordering. The built-in best-practice scanner also audits your Dockerfile and suggests additional improvements for speed and security." },
        },
        {
          "@type": "Question",
          name: "Do I need Docker installed to use this tool?",
          acceptedAnswer: { "@type": "Answer", text: "No. The Dockerfile Generator runs entirely in your browser. No installation, no signup, and no data leaves your device. All generation happens client-side, keeping your source code and configuration completely private." },
        },
        {
          "@type": "Question",
          name: "What Dockerfile best practices does the tool follow?",
          acceptedAnswer: { "@type": "Answer", text: "Every generated Dockerfile follows Dockerfile best practices including multi-stage builds, non-root user execution, optimal layer caching, .dockerignore generation, and framework-specific optimizations. The built-in scanner also audits your Dockerfile against security and performance standards." },
        },
        {
          "@type": "Question",
          name: "Can I use this for production Dockerfiles?",
          acceptedAnswer: { "@type": "Answer", text: "Absolutely. Generated Dockerfiles follow the same patterns used by Vercel, Railway, and other production platforms. The tool supports 23+ frameworks and generates Dockerfile volume configurations, health checks, and environment handling suitable for production deployments." },
        },
        {
          "@type": "Question",
          name: "Which frameworks does the Dockerfile generator support?",
          acceptedAnswer: { "@type": "Answer", text: "Currently 23+: Node.js, Express, NestJS, Next.js, React, Vue, Python, Django, FastAPI, Flask, Java, Spring Boot, Quarkus, Go, Rust, Actix, PHP, Laravel, Ruby, Rails, .NET, Phoenix, and Gin. Each framework gets a tailored Dockerfile with optimized build steps." },
        },
        {
          "@type": "Question",
          name: "Is there a Dockerfile scanner to check for issues?",
          acceptedAnswer: { "@type": "Answer", text: "Yes. The built-in best-practice scanner audits your Dockerfile against security vulnerabilities, performance anti-patterns, and compliance standards. It provides a scored report with actionable recommendations to harden your Docker configuration before deployment." },
        },
      ],
    },
  ]}
>
  <Nav />
  <main id="main" class="relative">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-[var(--color-hairline)] py-16 md:py-24">
      <div class="absolute inset-x-0 top-0 -z-10 h-[420px] mesh-gradient"></div>
      <div class="absolute inset-x-0 top-0 -z-10 h-[420px] grid-pattern"></div>
      <Container>
        <div class="text-center">
          <Badge variant="new" class="mb-6">
            <span class="mr-1">●</span> Free &middot; No signup &middot; Open source
          </Badge>
          <h1 class="t-display-xl mx-auto max-w-3xl text-[var(--color-ink)]">
            Free Dockerfile Generator — Create Production-Ready Dockerfiles Online
          </h1>
          <p class="t-body-lg mx-auto mt-6 max-w-2xl text-[var(--color-body)]">
            The #1 online Dockerfile generator and Docker Compose generator. Pick your stack, tweak the options, and ship a multi-stage, security-scanned Dockerfile in seconds. Built-in best practices for Next.js, Spring Boot, FastAPI, Go, and 18 more frameworks.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <Button href="#generator" size="lg">
              Start generating
              <Icon name="arrow-right" size={16} />
            </Button>
            <Button href="/compose" variant="secondary" size="lg">
              Generate Compose
            </Button>
          </div>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm-strong text-[var(--color-ink)]"><Icon name="check-circle" size={14} class="text-[var(--color-success)]" /> 23 frameworks</span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm-strong text-[var(--color-ink)]"><Icon name="check-circle" size={14} class="text-[var(--color-success)]" /> Multi-stage builds</span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm-strong text-[var(--color-ink)]"><Icon name="check-circle" size={14} class="text-[var(--color-success)]" /> Best-practice scanner</span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm-strong text-[var(--color-ink)]"><Icon name="check-circle" size={14} class="text-[var(--color-success)]" /> Free download</span>
          </div>
        </div>
      </Container>
    </section>

    <!-- Generator -->
    <section id="generator" class="py-12 md:py-20">
      <Container>
        <DockerfileGenerator />
      </Container>
    </section>

    <!-- Features grid -->
    <section data-reveal class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas)] py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Features</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">A modern Dockerfile generator with everything you need.</h2>
          <p class="t-body-md mx-auto mt-3 max-w-2xl text-[var(--color-body)]">
            Every Dockerfile is generated with security, performance, and Dockerfile best practices in mind.
          </p>
        </div>
        <div data-reveal-children class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: "layers", title: "Multi-stage builds", desc: "Smaller final images with build dependencies isolated to a builder stage." },
            { icon: "shield", title: "Security first", desc: "Non-root users, distroless base images, and CVE-respecting versions out of the box." },
            { icon: "zap", title: "Built for caching", desc: "Layer order optimized for Docker's build cache. Rebuild in seconds, not minutes." },
            { icon: "rocket", title: "Framework-specific", desc: "Spring Boot layered JARs, Next.js standalone output, FastAPI uvicorn tuning — done right." },
            { icon: "info", title: "Learn as you go", desc: "Every instruction is explained inline. Understand what your Dockerfile actually does." },
            { icon: "package", title: "Export everything", desc: "Dockerfile, .dockerignore, .env.example, and zip packages. Ready to commit." },
          ].map((f) => (
            <div class="card-hover rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6 shadow-[var(--shadow-level-2)]">
              <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-canvas-soft-2)] text-[var(--color-ink)]">
                <Icon name={f.icon} size={18} />
              </div>
              <h3 class="t-display-sm mb-2 text-[var(--color-ink)]">{f.title}</h3>
              <p class="t-body-md text-[var(--color-body)]">{f.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Best practices scanner — emphasized band -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="ambient-glow relative py-20 md:py-24">
      <Container>
        <div class="relative z-10 grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="t-caption-mono mb-3 text-[var(--color-body)]">Scanner</p>
            <h2 class="t-display-lg mb-4"><span class="gradient-text">A built-in Dockerfile best-practice auditor.</span></h2>
            <p class="t-body-lg mb-6 text-[var(--color-body)]">
              Every generated Dockerfile is scanned against Docker security and performance best practices. You'll see warnings for running as root, missing health checks, oversized base images, and more — ensuring your Dockerfile example is production-ready.
            </p>
            <ul class="space-y-3">
              {[
                "Running as root",
                "Missing health checks",
                "Large image size",
                "Missing .dockerignore",
                "Missing production optimization",
                "Sub-optimal layer caching",
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-ink)]"></span>
                  <span class="t-body-md text-[var(--color-body)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="card-hover relative z-10 rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6 shadow-[var(--shadow-level-4)]">
            <div class="mb-4 flex items-center justify-between">
              <span class="t-code text-[var(--color-body)]">scanner-report.json</span>
              <Badge variant="warning">3 issues</Badge>
            </div>
            <div class="space-y-3">
              {[
                { level: "warning", title: "Running as root", desc: "Add USER instruction" },
                { level: "warning", title: "Missing health check", desc: "Add HEALTHCHECK" },
                { level: "info", title: "Consider distroless", desc: "Reduce image size by 90%" },
              ].map((f) => (
                <div class="flex items-start gap-3 rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] p-3">
                  <span class={`t-caption-mono rounded-full px-2 py-0.5 ${f.level === "warning" ? "bg-[var(--color-warning-soft)] text-[var(--color-warning-deep)]" : "bg-[var(--color-link-bg-soft)] text-[var(--color-link)]"}`}>{f.level}</span>
                  <div>
                    <p class="t-body-sm-strong text-[var(--color-ink)]">{f.title}</p>
                    <p class="t-caption text-[var(--color-body)]">{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Frameworks -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="bg-[var(--color-canvas)] py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Frameworks</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Dockerfile generator for 23+ frameworks.</h2>
        </div>
        <div data-reveal-children class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-8">
          {[
            "Node.js", "Express", "NestJS", "Next.js", "React", "Vue",
            "Python", "Django", "FastAPI", "Flask",
            "Java", "Spring Boot", "Quarkus", "Go", "Rust", "Actix",
            "PHP", "Laravel", "Ruby", "Rails", ".NET", "Phoenix", "Gin",
          ].map((f) => (
            <div class="fw-badge rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] p-3 text-center t-body-sm text-[var(--color-ink)]">{f}</div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Education -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="border-y border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Education</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Learn Docker as you generate — your Dockerfile reference guide.</h2>
          <p class="t-body-md mx-auto mt-3 max-w-2xl text-[var(--color-body)]">
            Every instruction in your generated Dockerfile is explained in plain English. Understand Dockerfile volume mounts, layer caching, and more.
          </p>
        </div>
        <div data-reveal-children class="mx-auto grid max-w-3xl grid-cols-1 gap-3 md:grid-cols-2">
          {[
            { ins: "FROM node:20-alpine", desc: "Lightweight Node.js base image with Alpine Linux (~50MB)." },
            { ins: "WORKDIR /app", desc: "Sets the working directory for subsequent instructions." },
            { ins: "COPY --from=deps", desc: "Copies node_modules from the deps stage to the runner." },
            { ins: "USER appuser", desc: "Switches to a non-root user for security hardening." },
            { ins: "HEALTHCHECK", desc: "Tells Docker how to test if the container is healthy." },
            { ins: "EXPOSE 3000", desc: "Documents the port the container listens on at runtime." },
          ].map((e) => (
            <div class="card-hover rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-4">
              <code class="t-code block text-[var(--color-ink)]">$ {e.ins}</code>
              <p class="t-body-sm mt-2 text-[var(--color-body)]">{e.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Use cases -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="py-20 md:py-24">
      <Container>
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">Use cases</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Dockerfile generator for every use case.</h2>
        </div>
        <div data-reveal-children class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {[
            { title: "Bootstrapping a new project", desc: "Skip the boilerplate. Get a working, optimized Dockerfile in 30 seconds and focus on your application code." },
            { title: "Migrating to a slimmer image", desc: "Switch from a 1.2GB node image to a 50MB alpine image. Or jump to distroless for a 2MB Go binary." },
            { title: "Onboarding new engineers", desc: "New to Docker? Use the inline explanations to learn what each instruction does while you generate." },
            { title: "Reviewing an existing Dockerfile", desc: "Drop in your current Dockerfile and the scanner surfaces security, performance, and best-practice issues." },
          ].map((u) => (
            <div class="card-hover rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-6">
              <h3 class="t-display-sm mb-2 text-[var(--color-ink)]">{u.title}</h3>
              <p class="t-body-md text-[var(--color-body)]">{u.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- SEO Content Section -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="bg-[var(--color-canvas)] py-20 md:py-24">
      <Container>
        <article class="mx-auto max-w-3xl">
          <h2 class="t-display-lg mb-6 text-[var(--color-ink)]">Dockerfile Generator — The Ultimate Online Tool for Docker Configuration</h2>
          <div class="space-y-6 t-body-md text-[var(--color-body)]">
            <p>
              Generating a <strong>dockerfile</strong> no longer has to be a tedious, error-prone process. Our <strong>online Dockerfile generator</strong> helps developers create production-ready container configurations in seconds — without memorizing syntax or hunting through documentation. Whether you are building a microservices architecture with <strong>Docker Compose</strong> or containerizing a single application, this tool gives you a head start with best-practice defaults baked in. It is the fastest way to go from source code to a running container.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Why Use an Online Dockerfile Generator?</h3>
            <p>
              Writing a Dockerfile by hand is possible, but it often leads to common mistakes: running containers as root, bloated image sizes, missing <code>.dockerignore</code> files, or inefficient layer caching. An <strong>online Dockerfile generator</strong> eliminates these pitfalls by producing optimized configurations based on proven patterns. Our <strong>Dockerfile generator GUI</strong> lets you visually select your framework, choose a base image, configure environment variables, and instantly download a ready-to-use Dockerfile — all without touching the command line. The interface walks you through every decision, so even developers new to Docker can generate a correct, secure Dockerfile on their first try.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Docker Compose Generator for Multi-Service Applications</h3>
            <p>
              Modern applications rarely run in isolation. A <strong>Docker Compose generator</strong> simplifies orchestrating multiple services — databases, caches, message queues, and application servers — into a single <code>docker-compose.yml</code> file. Our <strong>Docker Compose generator online</strong> lets you add PostgreSQL, MySQL, MongoDB, Redis, Nginx, and other popular services with a few clicks. The generated compose file includes proper networking, volume mounts, health checks, and environment variable configuration. Use it as a <strong>Docker Compose generator GUI</strong> to visually build your stack, or download the YAML and customize it further. Every service is wired together with dependency-aware defaults, so your app starts in the right order every time.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Dockerfile Best Practices Built In</h3>
            <p>
              Every Dockerfile our tool generates follows <strong>Dockerfile best practices</strong> recommended by Docker and the wider community. This includes using multi-stage builds to keep final images small, running as a non-root user for security, ordering instructions for optimal cache hits, and using <code>.dockerignore</code> to exclude unnecessary files. The built-in best-practice scanner reviews your generated Dockerfile and flags issues like missing health checks, oversized base images, or insecure configurations. Think of it as a <strong>Dockerfile reference</strong> guide that actively helps you write better container configurations, turning every generation into a learning opportunity.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Understanding Dockerfile Volumes and Storage</h3>
            <p>
              Persistent data in Docker requires proper volume configuration. Our generator helps you set up <strong>Dockerfile volume</strong> declarations correctly, ensuring your containerized applications can store and retrieve data across restarts. Combined with the Docker Compose generator, you can define named volumes, bind mounts, and volume drivers — all from a visual interface. This makes it easy to manage stateful services like databases without diving into complex CLI commands.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Dockerfile Examples for Every Framework</h3>
            <p>
              Need a <strong>Dockerfile example</strong> for a specific stack? Our generator supports 23+ frameworks including Node.js, Express, NestJS, Next.js, Python, Django, FastAPI, Flask, Java, Spring Boot, Go, Rust, PHP, Laravel, Ruby, Rails, .NET, and more. Each generated Dockerfile is tailored to the framework's unique requirements — from Spring Boot's layered JARs to Next.js standalone output. You get a working <strong>Dockerfile example</strong> that you can extend or modify as your project evolves, complete with inline explanations for every instruction.
            </p>

            <h3 class="t-display-sm text-[var(--color-ink)]">Start Generating Your Dockerfile Online Today</h3>
            <p>
              Whether you need a quick <strong>Dockerfile example</strong> to get started or a full <strong>Docker Compose generator</strong> for a production deployment, our tool has you covered. No signup, no cost, and no data leaves your browser. The entire generation happens client-side, keeping your source code and configuration private. Try the <strong>Dockerfile generator online</strong> now and see how fast you can go from code to container.
            </p>
          </div>
        </article>
      </Container>
    </section>

    <!-- FAQ -->
    <div class="gradient-divider mx-auto max-w-5xl"></div>
    <section data-reveal class="py-20 md:py-24">
      <Container size="md">
        <div class="mb-12 text-center">
          <p class="t-caption-mono mb-3 text-[var(--color-body)]">FAQ</p>
          <h2 class="t-display-lg text-[var(--color-ink)]">Dockerfile generator — common questions.</h2>
        </div>
        <div class="divide-y divide-[var(--color-hairline)] rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)]" id="faq-list">
          {[
            { q: "What is a Dockerfile generator?", a: "A Dockerfile generator is an online tool that automatically creates production-ready Dockerfiles based on your project's framework and configuration. Our Dockerfile generator online eliminates manual writing by generating optimized, best-practice compliant Docker configurations with multi-stage builds and security hardening built in." },
            { q: "How does the Docker Compose generator work?", a: "The Docker Compose generator lets you visually configure services like PostgreSQL, MySQL, MongoDB, Redis, and Nginx, then generates a complete docker-compose.yml file with proper networking, volumes, and environment variables. Use it as a Docker Compose generator GUI to build your multi-service stack without writing YAML by hand." },
            { q: "Is this Dockerfile generator free to use?", a: "Yes. The Dockerfile Generator is completely free for personal and commercial use. No signup required. The generated Dockerfiles and docker-compose files are yours to keep, modify, and deploy." },
            { q: "How do I create a Dockerfile for my project?", a: "Simply select your project's framework from the list of 23+ supported options, configure your build settings visually, and click generate. The tool produces a complete, optimized Dockerfile tailored to your stack — no Docker knowledge required. You can copy, download, or export the result as a zip file." },
            { q: "What is a multi-stage Docker build and why should I use it?", a: "A multi-stage Docker build uses multiple build stages in a single Dockerfile to separate build dependencies from the final runtime image. This drastically reduces image size, improves security by excluding dev tools, and speeds up deployment. Every Dockerfile generated by our tool uses multi-stage builds by default." },
            { q: "Can I generate a docker-compose.yml with a database?", a: "Yes. The Docker Compose generator supports adding PostgreSQL, MySQL, MongoDB, Redis, MariaDB, and other services with a few clicks. It auto-configures networking, persistent volumes, environment variables, and health checks so your multi-container stack works out of the box." },
            { q: "How do I optimize my Dockerfile for faster builds?", a: "Our generator automatically applies Dockerfile optimization techniques: multi-stage builds, layer caching, minimal base images, .dockerignore generation, and dependency install ordering. The built-in best-practice scanner also audits your Dockerfile and suggests additional improvements for speed and security." },
            { q: "Do I need Docker installed to use this tool?", a: "No. The Dockerfile Generator runs entirely in your browser. No installation, no signup, and no data leaves your device. All generation happens client-side, keeping your source code and configuration completely private." },
            { q: "What Dockerfile best practices does the tool follow?", a: "Every generated Dockerfile follows Dockerfile best practices including multi-stage builds, non-root user execution, optimal layer caching, .dockerignore generation, and framework-specific optimizations. The built-in scanner also audits your Dockerfile against security and performance standards." },
            { q: "Can I use this for production Dockerfiles?", a: "Absolutely. Generated Dockerfiles follow the same patterns used by Vercel, Railway, and other production platforms. The tool supports 23+ frameworks and generates Dockerfile volume configurations, health checks, and environment handling suitable for production deployments." },
            { q: "Which frameworks does the Dockerfile generator support?", a: "Currently 23+: Node.js, Express, NestJS, Next.js, React, Vue, Python, Django, FastAPI, Flask, Java, Spring Boot, Quarkus, Go, Rust, Actix, PHP, Laravel, Ruby, Rails, .NET, Phoenix, and Gin. Each framework gets a tailored Dockerfile with optimized build steps." },
            { q: "Is there a Dockerfile scanner to check for issues?", a: "Yes. The built-in best-practice scanner audits your Dockerfile against security vulnerabilities, performance anti-patterns, and compliance standards. It provides a scored report with actionable recommendations to harden your Docker configuration before deployment." },
          ].map((item, i) => (
            <details class="group p-5" open={i === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                <span class="t-body-md-strong text-[var(--color-ink)]">{item.q}</span>
                <span class="text-[var(--color-body)] transition-transform group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <p class="t-body-md mt-3 text-[var(--color-body)]">{item.a}</p>
            </details>
          ))}
        </div>

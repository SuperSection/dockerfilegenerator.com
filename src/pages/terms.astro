---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
---

<Layout
  title="Terms & Conditions — Dockerfile Generator"
  description="Terms and Conditions for using Dockerfile Generator. Read our terms of service for using our free online Dockerfile and Docker Compose generator tools."
  keywords="terms and conditions, terms of service, dockerfile generator terms"
  canonical="https://dockerfilegenerator.com/terms"
>
  <Nav />
  <main id="main">
    <section class="py-16 md:py-24">
      <Container size="md">
        <a href="/" class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm text-[var(--color-body)] transition-colors hover:border-[var(--color-mute)] hover:text-[var(--color-ink)]">
          <Icon name="arrow-left" size={16} /> Back to Home
        </a>
        <h1 class="t-display-xl mb-4 text-[var(--color-ink)]">Terms & Conditions</h1>
        <p class="mb-8 inline-block rounded-full bg-[var(--color-canvas-soft-2)] px-3 py-1 t-caption text-[var(--color-body)]">Last updated on June 16, 2026</p>

        <div class="space-y-8 t-body-md text-[var(--color-body)]">
          <p>
            Welcome to Dockerfile Generator. By accessing or using our website and tools, you agree to be bound by these Terms and Conditions. If you do not agree with these terms, please do not use our service.
          </p>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Use of Service</h2>
            <p class="mb-3">
              Dockerfile Generator is provided free of charge for personal and commercial use. You may use the generated Dockerfiles, Docker Compose files, and related outputs for any purpose without restriction.
            </p>
            <p>
              You agree not to use the service for any unlawful purpose or in any way that could damage, disable, or impair the service.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Intellectual Property</h2>
            <p class="mb-3">
              The website, its design, code, and tools are owned by Dockerfile Generator and are protected by copyright and intellectual property laws.
            </p>
            <p>
              Any Dockerfiles or configurations generated using our tool are yours. We claim no ownership over the output you create. You are free to use, modify, and distribute generated content without attribution.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">No Warranty</h2>
            <p>
              The service is provided "as is" and "as available" without warranties of any kind. We do not guarantee that the service will be uninterrupted, error-free, or completely secure. Generated Dockerfiles should be reviewed and tested before use in production environments.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Limitation of Liability</h2>
            <p>
              In no event shall Dockerfile Generator, its developers, or affiliates be liable for any indirect, incidental, special, consequential, or punitive damages arising out of your use of the service. You use the service at your own risk.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Third-Party Links</h2>
            <p>
              Our website may contain links to third-party websites or services. We are not responsible for the content, privacy practices, or availability of these external sites. Use of third-party links is at your own risk.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Changes to Terms</h2>
            <p>
              We reserve the right to modify these Terms and Conditions at any time. Changes will be effective immediately upon posting. Your continued use of the service after changes are posted constitutes acceptance of the updated terms.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Termination</h2>
            <p>
              We may terminate or suspend your access to the service at any time, without prior notice, for conduct that we believe violates these terms or is harmful to other users or the service.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Contact Us</h2>
            <p>
              If you have questions about these Terms and Conditions, please <a href="/contact" class="text-[var(--color-link)] hover:underline">contact us</a>.
            </p>
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

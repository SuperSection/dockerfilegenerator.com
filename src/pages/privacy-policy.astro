---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
---

<Layout
  title="Privacy Policy — Dockerfile Generator"
  description="Privacy Policy for Dockerfile Generator. Learn how we collect, use, and protect your information when using our online Dockerfile generator tool."
  keywords="privacy policy, dockerfile generator privacy, data protection"
  canonical="https://dockerfilegenerator.soumosarkar.online/privacy-policy"
>
  <Nav />
  <main id="main">
    <section class="py-16 md:py-24">
      <Container size="md">
        <a href="/" class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm text-[var(--color-body)] transition-colors hover:border-[var(--color-mute)] hover:text-[var(--color-ink)]">
          <Icon name="arrow-left" size={16} /> Back to Home
        </a>
        <h1 class="t-display-xl mb-4 text-[var(--color-ink)]">Privacy Policy</h1>
        <p class="mb-8 inline-block rounded-full bg-[var(--color-canvas-soft-2)] px-3 py-1 t-caption text-[var(--color-body)]">Last updated on June 16, 2026</p>

        <div class="space-y-8 t-body-md text-[var(--color-body)]">
          <p>
            Dockerfile Generator ("we", "our", or "operates") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website and use our online tools.
          </p>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Information We Collect</h2>
            <p class="mb-3">
              We do not collect any personal information from our users. The Dockerfile Generator runs entirely in your browser. No data, source code, or configuration you enter is transmitted to our servers.
            </p>
            <p>
              We may collect non-personal information automatically when you visit our website, such as your browser type, operating system, referring URLs, and pages visited. This information is used solely to improve our website and user experience.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">How We Use Your Information</h2>
            <p class="mb-3">We may use the non-personal information we collect to:</p>
            <ul class="list-disc space-y-2 pl-6">
              <li>Improve and optimize our website and tools</li>
              <li>Analyze usage patterns and trends</li>
              <li>Monitor and prevent security threats</li>
              <li>Comply with legal obligations</li>
            </ul>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Cookies</h2>
            <p class="mb-3">
              We use essential cookies to ensure our website functions properly. We may also use analytics cookies (such as those provided by Google Analytics) to understand how visitors interact with our website. You can control cookie settings through your browser preferences.
            </p>
            <p>
              The only local storage we use is to remember your theme preference (dark or light mode). This data never leaves your device.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Third-Party Services</h2>
            <p class="mb-3">Our website may use the following third-party services:</p>
            <ul class="list-disc space-y-2 pl-6">
              <li><strong>Google Analytics:</strong> To analyze website traffic and usage patterns. Google Analytics uses cookies to collect information about your use of our website.</li>
              <li><strong>Vercel:</strong> Our website is hosted on Vercel, which may collect basic server logs for security and performance purposes.</li>
            </ul>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Data Security</h2>
            <p>
              We implement appropriate security measures to protect the limited information we collect. Since all Dockerfile generation happens client-side in your browser, your code and configurations are never transmitted to our servers.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Children's Privacy</h2>
            <p>
              Our website is not intended for use by children under the age of 13. We do not knowingly collect personal information from children under 13.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Changes to This Policy</h2>
            <p>
              We reserve the right to update this Privacy Policy at any time. Changes will be posted on this page with an updated "Last updated" date. We encourage you to review this policy periodically.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Contact Us</h2>
            <p>
              If you have questions about this Privacy Policy, please <a href="/contact" class="text-[var(--color-link)] hover:underline">contact us</a>.
            </p>
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Badge from "../components/ui/Badge.astro";
import MicroserviceBuilder from "../components/MicroserviceBuilder.astro";
---

<Layout
  title="Architecture Builder — Docker for any stack"
  description="Generate Docker setup for monolithic, two-tier, three-tier, or microservice architectures. Pick your architecture, configure services, and get production-ready Dockerfiles + docker-compose.yml."
>
  <Nav />
  <main id="main" class="relative">
    <section class="relative overflow-hidden border-b border-[var(--color-hairline)] py-12 md:py-16">
      <div class="absolute inset-x-0 top-0 -z-10 h-[320px] mesh-gradient-sm"></div>
      <Container>
        <div class="text-center">
          <Badge variant="new" class="mb-4">Architecture generator</Badge>
          <h1 class="t-display-xl mx-auto max-w-3xl text-[var(--color-ink)]">
            Docker for any architecture.
          </h1>
          <p class="t-body-lg mx-auto mt-4 max-w-2xl text-[var(--color-body)]">
            Choose your architecture. Configure services. Get production-ready Dockerfiles and docker-compose.yml.
          </p>
        </div>
      </Container>
    </section>

    <section class="py-12 md:py-20">
      <Container>
        <MicroserviceBuilder />
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

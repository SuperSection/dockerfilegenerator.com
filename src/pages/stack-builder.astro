---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Badge from "../components/ui/Badge.astro";
import StackBuilder from "../components/StackBuilder.astro";
---

<Layout
  title="Full Stack Builder — Docker Compose for any stack"
  description="Generate a complete Docker setup for your full-stack application. Frontend, backend, database, and optional services. Dockerfile + docker-compose.yml + .env.example in one click."
>
  <Nav />
  <main id="main" class="relative">
    <section class="relative overflow-hidden border-b border-[var(--color-hairline)] py-12 md:py-16">
      <div class="absolute inset-x-0 top-0 -z-10 h-[320px] mesh-gradient-sm"></div>
      <Container>
        <div class="text-center">
          <Badge variant="new" class="mb-4">Full-stack in one click</Badge>
          <h1 class="t-display-xl mx-auto max-w-3xl text-[var(--color-ink)]">
            Full stack, fully containerized.
          </h1>
          <p class="t-body-lg mx-auto mt-4 max-w-2xl text-[var(--color-body)]">
            Pick your frontend, backend, database, and optional services. Get a production-ready Docker setup — Dockerfile, docker-compose.yml, and .env.example — generated for you.
          </p>
        </div>
      </Container>
    </section>

    <section class="py-12 md:py-20">
      <Container>
        <StackBuilder />
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

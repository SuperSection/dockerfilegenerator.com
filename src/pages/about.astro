---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
---

<Layout
  title="About Us — Dockerfile Generator"
  description="Learn about Dockerfile Generator, the free online tool that helps developers create production-ready Dockerfiles and Docker Compose configurations in seconds."
  keywords="about dockerfile generator, docker compose generator about, online dockerfile tool"
  canonical="https://dockerfilegenerator.com/about"
>
  <Nav />
  <main id="main">
    <section class="py-16 md:py-24">
      <Container size="md">
        <a href="/" class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2 t-body-sm text-[var(--color-body)] transition-colors hover:border-[var(--color-mute)] hover:text-[var(--color-ink)]">
          <Icon name="arrow-left" size={16} /> Back to Home
        </a>
        <h1 class="t-display-xl mb-8 text-[var(--color-ink)]">About Dockerfile Generator</h1>

        <div class="space-y-8 t-body-md text-[var(--color-body)]">
          <p>
            Dockerfile Generator is a free, open-source online tool that helps developers create production-ready Dockerfiles and Docker Compose configurations in seconds. Our mission is to make Docker containerization accessible to every developer, regardless of experience level.
          </p>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Why We Built This</h2>
            <p class="mb-3">
              Writing Dockerfiles by hand is error-prone and time-consuming. Developers often struggle with best practices, multi-stage builds, and framework-specific optimizations. We built Dockerfile Generator to eliminate these pain points and let you focus on what matters — shipping your application.
            </p>
            <p>
              Every Dockerfile generated by our tool follows industry best practices, including multi-stage builds for smaller images, non-root users for security, and optimal layer caching for faster builds.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">What Makes Us Different</h2>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              {[
                { icon: "shield", title: "Privacy First", desc: "Everything runs in your browser. Your source code and configurations never leave your device." },
                { icon: "layers", title: "Best Practices Built In", desc: "Every generated Dockerfile follows Docker and community best practices out of the box." },
                { icon: "zap", title: "Instant Generation", desc: "Get a production-ready Dockerfile in seconds, not hours of research and debugging." },
                { icon: "info", title: "Learn As You Go", desc: "Every instruction is explained inline, making it a learning tool as well as a generator." },
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <div class="mt-1 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-[var(--color-canvas-soft-2)] text-[var(--color-ink)]">
                    <Icon name={item.icon} size={14} />
                  </div>
                  <div>
                    <h3 class="t-body-md-strong text-[var(--color-ink)]">{item.title}</h3>
                    <p class="t-body-sm text-[var(--color-body)]">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Supported Frameworks</h2>
            <p class="mb-3">
              We currently support 23+ frameworks including Node.js, Express, NestJS, Next.js, React, Vue, Python, Django, FastAPI, Flask, Java, Spring Boot, Quarkus, Go, Rust, Actix, PHP, Laravel, Ruby, Rails, .NET, Phoenix, and Gin. Each framework gets a tailored Dockerfile with optimized build steps.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Open Source</h2>
            <p>
              Dockerfile Generator is open source and available on <a href="https://github.com/SuperSection/dockerfilegenerator.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-link)] hover:underline">GitHub</a>. Contributions, bug reports, and feature requests are welcome. We believe in building tools in the open with the developer community.
            </p>
          </div>

          <div>
            <h2 class="t-display-sm mb-3 text-[var(--color-ink)]">Get In Touch</h2>
            <p>
              Have questions, feedback, or want to collaborate? Visit our <a href="/contact" class="text-[var(--color-link)] hover:underline">contact page</a> to reach out. We'd love to hear from you.
            </p>
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</Layout>

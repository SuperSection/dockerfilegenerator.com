    `;

    // Dockerfile panels
    for (const id of dfIds) {
      const df = generateMicroserviceDockerfile(id, cfg);
      const isActive = state.activeTab === `df-${id}`;
      html += `
        <div id="ms-panel-df-${id}" class="ms-panel rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] overflow-hidden ${!isActive ? "hidden" : ""}">
          <div class="flex items-center justify-between border-b border-[var(--color-hairline)] bg-[var(--color-canvas-soft-2)] px-4 py-2">
            <span class="font-mono text-[13px] text-[var(--color-body)]">${id}/Dockerfile</span>

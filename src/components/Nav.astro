---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./ui/Icon.astro";
---

<style>
  /* Hamburger → X transition */
  #mobile-menu-btn svg line {
    transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 200ms ease;
    transform-origin: center;
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu slide-down + fade */
  #mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    border-top: 0px solid transparent;
    padding-top: 0;
    padding-bottom: 0;
    transition: grid-template-rows 300ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 250ms ease,
                border-top 200ms ease,
                padding 200ms ease;
    overflow: hidden;
  }
  #mobile-menu.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    border-top-width: 1px;
    border-top-color: var(--color-hairline);
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  #mobile-menu > div {
    min-height: 0;
  }

  /* Staggered link entrance */
  #mobile-menu.is-open .mobile-nav-link {
    animation: mobileLinkIn 280ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  #mobile-menu.is-open .mobile-nav-link:nth-child(1) { animation-delay: 40ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(2) { animation-delay: 80ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(3) { animation-delay: 120ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(4) { animation-delay: 160ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(5) { animation-delay: 200ms; }

  @keyframes mobileLinkIn {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Active press feedback on links */
  .mobile-nav-link:active {
    transform: scale(0.97);
    transition: transform 80ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-menu,
    #mobile-menu svg line,
    #mobile-menu .mobile-nav-link {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<header
  class="sticky top-0 z-40 w-full border-b border-[var(--color-hairline)] nav-bg backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 w-full max-w-[1280px] items-center justify-between px-4 md:px-6"
    aria-label="Primary"
  >
    <Logo />

    <!-- Desktop nav -->
    <div class="hidden items-center gap-1 md:flex">
      <a
        href="/"
        class="rounded-full px-3 py-1.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus:outline focus:outline-2 focus:outline-[var(--color-link)] focus:outline-offset-2"
        >Dockerfile</a
      >
      <a
        href="/compose"
        class="rounded-full px-3 py-1.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus:outline focus:outline-2 focus:outline-[var(--color-link)] focus:outline-offset-2"
        >Compose</a
      >
      <a
        href="/stack-builder"
        class="rounded-full px-3 py-1.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus:outline focus:outline-2 focus:outline-[var(--color-link)] focus:outline-offset-2"
        >Stack Builder</a
      >
      <a
        href="https://docs.docker.com/compose/intro/compose-application-model/"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full px-3 py-1.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus:outline focus:outline-2 focus:outline-[var(--color-link)] focus:outline-offset-2"
        >Docs</a
      >
    </div>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/SuperSection/dockerfilegenerator.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden h-9 items-center gap-2 rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] px-3 t-body-sm-strong text-[var(--color-ink)] transition-colors hover:bg-[var(--color-canvas-soft-2)] sm:inline-flex"
      >
        <Icon name="github" size={14} />
        <span>Star</span>
      </a>
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] text-[var(--color-ink)] md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="bg-[var(--color-canvas)] px-4 md:hidden"
  >
    <div class="flex flex-col gap-1">
      <a href="/" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">Dockerfile</a>
      <a href="/compose" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">Compose</a>
      <a href="/stack-builder" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">Stack Builder</a>
      <a href="https://docs.docker.com/compose/intro/compose-application-model/" target="_blank" rel="noopener noreferrer" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">Docs</a>
      <a href="https://github.com/SuperSection/dockerfilegenerator.com" target="_blank" rel="noopener noreferrer" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">GitHub</a>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    const menu = document.getElementById("mobile-menu");
    const btn = document.getElementById("mobile-menu-btn");
    if (!menu || !btn) return;
    const isOpen = menu.classList.toggle("is-open");
    btn.setAttribute("aria-expanded", String(isOpen));
    btn.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
  });
</script>

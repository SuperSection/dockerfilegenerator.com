---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./ui/Icon.astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const path = href.replace(/\/$/, "") || "/";
  return path === pathname;
};
---

<style>
  /* Hamburger → X transition */
  #mobile-menu-btn svg line {
    transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 200ms ease;
    transform-origin: center;
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] svg line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu slide-down + fade */
  #mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    border-top: 0px solid transparent;
    padding-top: 0;
    padding-bottom: 0;
    transition: grid-template-rows 300ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 250ms ease,
                border-top 200ms ease,
                padding 200ms ease;
    overflow: hidden;
  }
  #mobile-menu.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    border-top-width: 1px;
    border-top-color: var(--color-hairline);
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }
  #mobile-menu > div {
    min-height: 0;
  }

  /* Staggered link entrance */
  #mobile-menu.is-open .mobile-nav-link {
    animation: mobileLinkIn 280ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  #mobile-menu.is-open .mobile-nav-link:nth-child(1) { animation-delay: 20ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(2) { animation-delay: 40ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(3) { animation-delay: 60ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(4) { animation-delay: 80ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(5) { animation-delay: 100ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(6) { animation-delay: 120ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(7) { animation-delay: 140ms; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(8) { animation-delay: 160ms; }

  @keyframes mobileLinkIn {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .mobile-nav-link:active {
    transform: scale(0.97);
    transition: transform 80ms ease;
  }

  /* Desktop nav links — smooth transitions */
  .nav-link {
    transition: background-color 200ms ease, color 200ms ease;
  }

  /* Active page indicator — desktop */
  .nav-link-active {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-ink);
  }
  html.dark .nav-link-active {
    background-color: rgba(255, 255, 255, 0.1);
  }
  html:not(.dark) .nav-link-active {
    background-color: rgba(0, 0, 0, 0.08);
  }

  /* Active page indicator — mobile */
  .mobile-nav-active {
    background-color: var(--color-canvas-soft-2);
    color: var(--color-ink);
    font-weight: 600;
    position: relative;
  }
  .mobile-nav-active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 25%;
    bottom: 25%;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background-color: var(--color-link);
  }

  /* Active page indicator — More dropdown */
  .more-link-active {
    background-color: var(--color-canvas-soft-2);
    color: var(--color-ink);
    font-weight: 600;
  }

  /* Desktop "More" dropdown — wrapper hover */
  .more-group {
    position: relative;
  }
  .more-group .more-panel {
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease, visibility 150ms ease;
    pointer-events: none;
  }
  .more-group:hover .more-panel,
  .more-group:focus-within .more-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Responsive: hide info links + sep on md/lg, show More btn; reverse on xl */
  .nav-link-info,
  .nav-sep {
    display: none;
  }
  .nav-more-btn {
    display: flex;
  }
  @media (min-width: 1280px) {
    .nav-link-info,
    .nav-sep {
      display: flex;
    }
    .nav-more-btn {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-menu,
    #mobile-menu svg line,
    #mobile-menu .mobile-nav-link {
      transition: none !important;
      animation: none !important;
    }
    .more-group .more-panel {
      transition: none !important;
    }
  }
</style>

<header
  class="sticky top-0 z-40 w-full border-b border-[var(--color-hairline)] nav-bg backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 w-full max-w-[1280px] items-center justify-between px-4 md:px-6"
    aria-label="Primary"
  >
    <Logo />

    <!-- Desktop nav — all links flat on xl, collapse info links on md/lg -->
    <div class="hidden items-center md:flex">
      <!-- Tool links — always visible on desktop -->
      <a href="/" class:list={["nav-link rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/") && "nav-link-active"]} aria-current={isActive("/") ? "page" : undefined}>Dockerfile</a>
      <a href="/compose" class:list={["nav-link rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/compose") && "nav-link-active"]} aria-current={isActive("/compose") ? "page" : undefined}>Compose</a>
      <a href="/stack-builder" class:list={["nav-link rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", pathname.startsWith("/stack-builder") && "nav-link-active"]} aria-current={pathname.startsWith("/stack-builder") ? "page" : undefined}>Stack Builder</a>
      <a href="https://docs.docker.com/compose/intro/compose-application-model/" target="_blank" rel="noopener noreferrer" class="nav-link rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2">Docs</a>

      <!-- Separator between tools and info -->
      <span class="nav-sep mx-2 h-5 w-px bg-[var(--color-hairline)]" aria-hidden="true"></span>

      <!-- Info links — flat on xl only -->
      <a href="/about" class:list={["nav-link-info rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/about") && "nav-link-active"]} aria-current={isActive("/about") ? "page" : undefined}>About</a>
      <a href="/contact" class:list={["nav-link-info rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/contact") && "nav-link-active"]} aria-current={isActive("/contact") ? "page" : undefined}>Contact</a>
      <a href="/privacy-policy" class:list={["nav-link-info rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/privacy-policy") && "nav-link-active"]} aria-current={isActive("/privacy-policy") ? "page" : undefined}>Privacy</a>
      <a href="/terms" class:list={["nav-link-info rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2", isActive("/terms") && "nav-link-active"]} aria-current={isActive("/terms") ? "page" : undefined}>Terms</a>

      <!-- More dropdown — visible on md/lg, hidden on xl -->
      <div class="more-group xl:hidden">
        <button
          type="button"
          class="nav-more-btn flex items-center gap-1.5 rounded-full px-3.5 py-2 t-body-md text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-link)] focus-visible:outline-offset-2"
        >
          More
          <Icon name="chevron-down" size={14} />
        </button>
        <div class="more-panel absolute right-0 top-full mt-1 w-52 rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas)] p-1.5 shadow-[var(--shadow-level-4)]">
          <a href="/about" class:list={["flex items-center gap-2.5 rounded-md px-3 py-2.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)]", isActive("/about") && "more-link-active"]}>
            <Icon name="info" size={14} /> About Us
          </a>
          <a href="/contact" class:list={["flex items-center gap-2.5 rounded-md px-3 py-2.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)]", isActive("/contact") && "more-link-active"]}>
            <Icon name="mail" size={14} /> Contact Us
          </a>
          <div class="my-1 h-px bg-[var(--color-hairline)]"></div>
          <a href="/privacy-policy" class:list={["flex items-center gap-2.5 rounded-md px-3 py-2.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)]", isActive("/privacy-policy") && "more-link-active"]}>
            <Icon name="shield" size={14} /> Privacy Policy
          </a>
          <a href="/terms" class:list={["flex items-center gap-2.5 rounded-md px-3 py-2.5 t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)]", isActive("/terms") && "more-link-active"]}>
            <Icon name="file" size={14} /> Terms & Conditions
          </a>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/SuperSection/dockerfilegenerator.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden h-9 items-center gap-2 rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] px-3 t-body-sm-strong text-[var(--color-ink)] transition-colors hover:bg-[var(--color-canvas-soft-2)] sm:inline-flex"
      >
        <Icon name="github" size={14} />
        <span>Star</span>
      </a>
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-hairline)] bg-[var(--color-canvas)] text-[var(--color-ink)] md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="bg-[var(--color-canvas)] px-4 md:hidden"
  >
    <div class="flex flex-col">
      <a href="/" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/") && "mobile-nav-active"]} aria-current={isActive("/") ? "page" : undefined}>Dockerfile</a>
      <a href="/compose" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/compose") && "mobile-nav-active"]} aria-current={isActive("/compose") ? "page" : undefined}>Compose</a>
      <a href="/stack-builder" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", pathname.startsWith("/stack-builder") && "mobile-nav-active"]} aria-current={pathname.startsWith("/stack-builder") ? "page" : undefined}>Stack Builder</a>
      <a href="https://docs.docker.com/compose/intro/compose-application-model/" target="_blank" rel="noopener noreferrer" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">Docs</a>
      <a href="https://github.com/SuperSection/dockerfilegenerator.com" target="_blank" rel="noopener noreferrer" class="mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]">GitHub</a>

      <div class="my-2 h-px bg-[var(--color-hairline)]"></div>

      <a href="/about" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/about") && "mobile-nav-active"]} aria-current={isActive("/about") ? "page" : undefined}>
        <Icon name="info" size={14} class="mr-2" /> About Us
      </a>
      <a href="/contact" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/contact") && "mobile-nav-active"]} aria-current={isActive("/contact") ? "page" : undefined}>
        <Icon name="mail" size={14} class="mr-2" /> Contact Us
      </a>
      <a href="/privacy-policy" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/privacy-policy") && "mobile-nav-active"]} aria-current={isActive("/privacy-policy") ? "page" : undefined}>
        <Icon name="shield" size={14} class="mr-2" /> Privacy Policy
      </a>
      <a href="/terms" class:list={["mobile-nav-link rounded-md px-3 py-3 min-h-[44px] flex items-center t-body-sm text-[var(--color-body)] transition-colors hover:bg-[var(--color-canvas-soft-2)] hover:text-[var(--color-ink)] active:bg-[var(--color-canvas-soft-3)]", isActive("/terms") && "mobile-nav-active"]} aria-current={isActive("/terms") ? "page" : undefined}>
        <Icon name="file" size={14} class="mr-2" /> Terms & Conditions
      </a>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    const menu = document.getElementById("mobile-menu");
    const btn = document.getElementById("mobile-menu-btn");
    if (!menu || !btn) return;
    const isOpen = menu.classList.toggle("is-open");
    btn.setAttribute("aria-expanded", String(isOpen));
    btn.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
  });

  document.addEventListener("click", (e) => {
    const menu = document.getElementById("mobile-menu");
    const btn = document.getElementById("mobile-menu-btn");
    if (!menu || !btn || !menu.classList.contains("is-open")) return;
    if (!menu.contains(e.target) && !btn.contains(e.target)) {
      menu.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Open menu");
    }
  });

  const mdBreakpoint = window.matchMedia("(min-width: 768px)");
  mdBreakpoint.addEventListener("change", (e) => {
    if (e.matches) {
      const menu = document.getElementById("mobile-menu");
      const btn = document.getElementById("mobile-menu-btn");
      if (menu && btn) {
        menu.classList.remove("is-open");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Open menu");
      }
    }
  });
</script>

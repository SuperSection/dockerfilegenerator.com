---
import Logo from "./Logo.astro";
---

<footer class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas-soft)]">
  <div class="mx-auto w-full max-w-[1280px] px-4 py-16 md:px-6 md:py-20">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-3 md:gap-12">
      <div class="col-span-2 md:col-span-1">
        <Logo />
        <p class="t-body-sm mt-4 max-w-xs text-[var(--color-body)]">
          Production-ready Dockerfiles and compose files, generated in seconds.
        </p>
      </div>

      <div>
        <h3 class="t-caption-mono mb-4 text-[var(--color-body)]">Tools</h3>
        <ul class="space-y-3">
          <li><a href="/" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">Dockerfile</a></li>
          <li><a href="/compose" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">Compose</a></li>
          <li><a href="/stack-builder" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">Stack Builder</a></li>
        </ul>
      </div>

      <div>
        <h3 class="t-caption-mono mb-4 text-[var(--color-body)]">Resources</h3>
        <ul class="space-y-3">
          <li><a href="https://docs.docker.com/compose/intro/compose-application-model/" target="_blank" rel="noopener" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">Docker Compose Docs</a></li>
          <li><a href="https://docs.docker.com/build/building/best-practices/" target="_blank" rel="noopener" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">Dockerfile Best Practices</a></li>
          <li><a href="https://github.com/SuperSection" target="_blank" rel="noopener" class="t-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)]">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-[var(--color-hairline)] pt-8 md:flex-row md:items-center">
      <p class="t-caption text-[var(--color-mute)]">
        &copy; 2026 Dockerfile Generator. All rights reserved.
      </p>
      <p class="t-caption text-[var(--color-mute)]">
        Made for developers who ship.
      </p>
    </div>
  </div>
</footer>
